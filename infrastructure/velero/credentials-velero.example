# ================================================================
# VELERO CREDENTIALS - AZURE STORAGE
# ⚠️  COPIER CE FICHIER EN "credentials-velero" ET REMPLIR LES VALEURS
# ⚠️  NE JAMAIS COMMITTER "credentials-velero" DANS GIT
# ================================================================

# Azure Subscription & Tenant
export AZURE_SUBSCRIPTION_ID="<votre-subscription-id>"
export AZURE_TENANT_ID="<votre-tenant-id>"

# Service Principal Credentials
export AZURE_CLIENT_ID="<sp-app-id>"
export AZURE_CLIENT_SECRET="<sp-secret>"

# Azure Configuration
export AZURE_RESOURCE_GROUP="<votre-resource-group>"
export AZURE_CLOUD_NAME="AzurePublicCloud"

# Storage Configuration
export AZURE_STORAGE_ACCOUNT_ID="<storage-account-name>"
export AZURE_STORAGE_ACCOUNT_KEY="<storage-account-key>"

# Velero Configuration
export VELERO_CONTAINER_NAME="velero-backups"
export VELERO_BUCKET_NAME="velero-backups"
